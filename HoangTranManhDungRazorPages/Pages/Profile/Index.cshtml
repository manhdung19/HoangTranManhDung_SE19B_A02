@page
@model HoangTranManhDungRazorPages.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="fw-bold">Hồ sơ cá nhân (Profile)</h2>
    <hr />

    @if (Model.SuccessMessage != null)
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    <!-- Nút dẫn sang trang xem lịch sử bài viết -->
    <a asp-page="./History" class="btn btn-info mb-4 text-white fw-bold">Xem lịch sử bài viết đã tạo</a>

    <form method="post" class="card p-4 shadow-sm border-0 bg-light">
        <div class="form-group mb-3">
            <label class="form-label fw-bold">Account ID</label>
            <input asp-for="SystemAccount.AccountId" class="form-control" readonly />
        </div>
        <div class="form-group mb-3">
            <label class="form-label fw-bold">Tên của bạn (Name)</label>
            <input asp-for="SystemAccount.AccountName" class="form-control" required />
            <span asp-validation-for="SystemAccount.AccountName" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label fw-bold">Email</label>
            <input asp-for="SystemAccount.AccountEmail" type="email" class="form-control" required />
            <span asp-validation-for="SystemAccount.AccountEmail" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label fw-bold">Mật khẩu (Password)</label>
            <input asp-for="SystemAccount.AccountPassword" type="text" class="form-control" required />
            <span asp-validation-for="SystemAccount.AccountPassword" class="text-danger"></span>
        </div>

        <input type="hidden" asp-for="SystemAccount.AccountRole" />

        <div class="text-end mt-3">
            <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
        </div>
    </form>
</div>
