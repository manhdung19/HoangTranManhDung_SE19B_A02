<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HoangTranManhDungRazorPages</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HoangTranManhDungRazorPages.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-page="/Home">📰 FUNewsManagement</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @{
                        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
                    }
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link @(currentPage == "/Home" || currentPage == "/Index" ? "active fw-bold text-white border-bottom border-light border-3" : "text-light")" asp-page="/Home">Trang Chủ (Public)</a>
                        </li>

                        @if (Context.Session.GetInt32("UserRole") == 0) // Admin
                        {
                            <li class="nav-item mx-1">
                                <a class="nav-link @(currentPage.StartsWith("/SystemAccount") ? "active fw-bold text-white border-bottom border-warning border-3" : "text-warning")" asp-page="/SystemAccount/Index">Quản lý Tài Khoản</a>
                            </li>
                            <li class="nav-item mx-1">
                                <a class="nav-link @(currentPage.StartsWith("/Report") ? "active fw-bold text-white border-bottom border-warning border-3" : "text-warning")" asp-page="/Report/Index">Thống kê Báo cáo</a>
                            </li>
                        }
                        else if (Context.Session.GetInt32("UserRole") == 1) // Staff
                        {
                            <li class="nav-item mx-1">
                                <a class="nav-link @(currentPage.StartsWith("/Category") ? "active fw-bold text-white border-bottom border-info border-3" : "text-info")" asp-page="/Category/Index">Quản lý Danh mục</a>
                            </li>
                            <li class="nav-item mx-1">
                                <a class="nav-link @(currentPage.StartsWith("/NewsArticle") ? "active fw-bold text-white border-bottom border-info border-3" : "text-info")" asp-page="/NewsArticle/Index">Quản lý Bài viết</a>
                            </li>
                            <li class="nav-item mx-1">
                                <a class="nav-link @(currentPage.StartsWith("/Profile") ? "active fw-bold text-white border-bottom border-info border-3" : "text-info")" asp-page="/Profile/Index">Hồ sơ cá nhân</a>
                            </li>
                        }
                        else if (Context.Session.GetInt32("UserRole") == 2) // Lecturer
                        {
                            <li class="nav-item mx-1">
                                <a class="nav-link @(currentPage.StartsWith("/Lecturer") ? "active fw-bold text-white border-bottom border-success border-3" : "text-success")" asp-page="/Lecturer/Index">Tin tức nội bộ</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light">Xin chào, @Context.Session.GetString("UserName")!</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-page="/Logout">Đăng Xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold" asp-page="/Login">Đăng Nhập</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Toast Notification cho SignalR -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
        <div id="liveToast" class="toast align-items-center text-white bg-success border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true" style="cursor: pointer;" onclick="window.location.reload();">
            <div class="d-flex">
                <div class="toast-body fw-bold" id="toastMessage">
                    <!-- Nơi hiển thị thông báo Real-time -->
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
        <div class="text-muted text-end" style="font-size: 0.8rem; display: none;" id="toastHint">Bấm vào thông báo để xem bài viết mới</div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - HoangTranManhDungRazorPages - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Thêm thư viện SignalR từ CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        var userRole = @(Context.Session.GetInt32("UserRole") ?? -1);
        
        // Theo yêu cầu: Chỉ Admin (0) và Lecturer (2) mới nhận được thông báo
        // Hoặc Staff (1) để test. Ta sẽ mở kết nối cho mọi user đã login.
        if (userRole === 0 || userRole === 1 || userRole === 2) {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/newshub")
                .build();

            connection.on("ReceiveNewsNotification", function (message) {
                // Hiển thị popup Toast
                document.getElementById("toastMessage").innerText = message;
                var toastEl = document.getElementById('liveToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 6000 }); // Hiện 6 giây
                toast.show();
                
                // Hiện thêm dòng chữ nhắc nhở
                document.getElementById('toastHint').style.display = 'block';
                setTimeout(() => document.getElementById('toastHint').style.display = 'none', 6000);
            });

            connection.start().then(function () {
                console.log("Đã kết nối tới SignalR NewsHub!");
            }).catch(function (err) {
                console.error("Lỗi kết nối SignalR: ", err.toString());
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>