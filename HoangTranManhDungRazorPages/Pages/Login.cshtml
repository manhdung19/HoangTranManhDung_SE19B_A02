@page
@model HoangTranManhDungRazorPages.Pages.LoginModel
@{
    ViewData["Title"] = "Đăng Nhập";
    Layout = null; // Cắt đứt thanh Menu để không bị vỡ giao diện
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Đăng Nhập - FUNewsManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh; position: relative;">

    <!-- Nút Trang chủ nằm cố định ở góc trên bên trái -->
    <a asp-page="/Home" class="btn btn-outline-secondary position-absolute top-0 start-0 m-4 fw-bold shadow-sm rounded-pill px-4">
        ← Về Trang chủ Public
    </a>

    <div class="card shadow-lg border-0 rounded-4" style="width: 400px;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <h3 class="card-title text-primary fw-bold">ĐĂNG NHẬP</h3>
                <p class="text-muted">Hệ thống FUNewsManagement</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger text-center rounded-3">@Model.ErrorMessage</div>
            }

            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Địa chỉ Email</label>
                    <input type="email" asp-for="Email" class="form-control form-control-lg bg-light" placeholder="Nhập email của bạn" required />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">Mật khẩu</label>
                    <input type="password" asp-for="Password" class="form-control form-control-lg bg-light" placeholder="Nhập mật khẩu..." required />
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold rounded-pill shadow-sm">Đăng Nhập Ngay</button>
            </form>
        </div>
    </div>

</body>
</html>
