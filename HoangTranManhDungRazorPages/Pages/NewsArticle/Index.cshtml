@page
@model HoangTranManhDungRazorPages.Pages.NewsArticle.IndexModel

@{
    ViewData["Title"] = "News Article Management";
}

<div class="container mt-4">
    <h2 class="text-primary fw-bold">Quản lý Bài viết (Staff)</h2>
    <hr />

    <div class="d-flex justify-content-between mb-3">
        <button class="btn btn-primary fw-bold shadow-sm" onclick="openCreatePopup()">+ Create New Article</button>

        <form method="get" class="d-flex">
            <input type="text" name="searchString" value="@Request.Query["searchString"]" class="form-control me-2" placeholder="Tìm kiếm tiêu đề..." style="width: 250px;" />
            <button type="submit" class="btn btn-secondary">Search</button>
            <a asp-page="./Index" class="btn btn-outline-secondary ms-2">Clear</a>
        </form>
    </div>

    <table class="table table-bordered table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tiêu đề</th>
                <th>Danh mục</th>
                <th>Người tạo</th>
                <th>Thẻ (Tags)</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.NewsArticles)
            {
                <tr>
                    <td>@item.NewsArticleId</td>
                    <td class="fw-bold">@item.NewsTitle</td>
                    <td>@(item.Category?.CategoryName ?? "N/A")</td>
                    <td>@(item.CreatedBy?.AccountName ?? "N/A")</td>
                    <td>
                        @if (item.Tags != null && item.Tags.Any())
                        {
                            @foreach (var t in item.Tags)
                            {
                                <span class="badge bg-info text-dark me-1">@t.TagName</span>
                            }
                        }
                    </td>
                    <td>
                        <span class="badge @(item.NewsStatus == true ? "bg-success" : "bg-danger") p-2">
                            @(item.NewsStatus == true ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-warning btn-sm fw-bold" onclick="openEditPopup('@item.NewsArticleId')">Edit</button>
                        <button class="btn btn-danger btn-sm fw-bold" onclick="deleteArticle('@item.NewsArticleId')">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="modal fade" id="articleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content" id="modal-content">
                <!-- Form HTML sẽ load vào đây -->
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        var token = $('input[name="__RequestVerificationToken"]').val();

        function openCreatePopup() {
            $.get('?handler=CreatePartial', function (data) {
                $('#modal-content').html(data);
                $('#articleModal').modal('show');
            });
        }

        function submitCreateForm(form) {
            $.ajax({
                type: 'POST',
                url: '?handler=Create',
                data: $(form).serialize(),
                headers: { "RequestVerificationToken": token },
                success: function (response) {
                    if (response.success) {
                        $('#articleModal').modal('hide');
                        location.reload();
                    } else {
                        $('#modal-content').html(response);
                    }
                }
            });
            return false;
        }

        function openEditPopup(id) {
            $.get('?handler=EditPartial&id=' + id, function (data) {
                $('#modal-content').html(data);
                $('#articleModal').modal('show');
            });
        }

        function submitEditForm(form) {
            $.ajax({
                type: 'POST',
                url: '?handler=Edit',
                data: $(form).serialize(),
                headers: { "RequestVerificationToken": token },
                success: function (response) {
                    if (response.success) {
                        $('#articleModal').modal('hide');
                        location.reload();
                    } else {
                        $('#modal-content').html(response);
                    }
                }
            });
            return false;
        }

        function deleteArticle(id) {
            if (confirm("Bạn có chắc chắn muốn xóa bài viết này?")) {
                $.ajax({
                    type: 'POST',
                    url: '?handler=Delete&id=' + id,
                    headers: { "RequestVerificationToken": token },
                    success: function (response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert("Xóa thất bại!");
                        }
                    }
                });
            }
        }
    </script>
}
