@model FUNewsManagement.DAL.Models.NewsArticle

<form asp-action="Edit" method="post" onsubmit="return submitEditForm(this);">
    <div class="modal-header">
        <h5 class="modal-title">Cập nhật bài viết</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>
    <div class="modal-body">
        <div class="form-group mb-3">
            <label class="form-label">NewsArticle ID</label>
            <input asp-for="NewsArticleId" class="form-control" readonly />
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Tiêu đề (Title)</label>
            <input asp-for="NewsTitle" class="form-control" required />
            <span asp-validation-for="NewsTitle" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Headline</label>
            <input asp-for="Headline" class="form-control" required />
            <span asp-validation-for="Headline" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Danh mục (Category)</label>
            <select asp-for="CategoryId" class="form-select" required>
                <option value="">-- Chọn danh mục --</option>
                @{
                    var categories = ViewData["Categories"] as List<FUNewsManagement.DAL.Models.Category> ?? new List<FUNewsManagement.DAL.Models.Category>();
                    foreach (var cat in categories)
                    {
                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                    }
                }
            </select>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Thẻ (Tags)</label>
            <select name="selectedTags" class="form-select" multiple>
                @{
                    var tags = ViewData["Tags"] as List<FUNewsManagement.DAL.Models.Tag> ?? new List<FUNewsManagement.DAL.Models.Tag>();
                    foreach (var tag in tags)
                    {
                        bool isSelected = Model.Tags != null && Model.Tags.Any(t => t.TagId == tag.TagId);
                        if (isSelected) {
                            <option value="@tag.TagId" selected>@tag.TagName</option>
                        } else {
                            <option value="@tag.TagId">@tag.TagName</option>
                        }
                    }
                }
            </select>
            <small class="text-muted">Giữ phím Ctrl (hoặc Cmd) để chọn nhiều Thẻ.</small>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Trạng thái (Status)</label>
            <select asp-for="NewsStatus" class="form-select">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
            </select>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
    </div>
</form>
