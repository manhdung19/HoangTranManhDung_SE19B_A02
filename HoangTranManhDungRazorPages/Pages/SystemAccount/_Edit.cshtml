@model FUNewsManagement.DAL.Models.SystemAccount

<form id="editForm" asp-action="Edit" method="post" onsubmit="return submitEditForm(this);">
    <div class="modal-header">
        <h5 class="modal-title">Cập nhật tài khoản</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>
    <div class="modal-body">
        <div class="form-group mb-3">
            <label class="form-label">Account ID</label>
            <!-- ID là duy nhất nên để readonly (chỉ đọc) để không cho sửa -->
            <input asp-for="AccountId" class="form-control" readonly />
            <span asp-validation-for="AccountId" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Name</label>
            <input asp-for="AccountName" class="form-control" required />
            <span asp-validation-for="AccountName" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Email</label>
            <input asp-for="AccountEmail" type="email" class="form-control" required />
            <span asp-validation-for="AccountEmail" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Password</label>
            <input asp-for="AccountPassword" type="password" class="form-control" required />
            <span asp-validation-for="AccountPassword" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Vai trò (Role)</label>
            <select asp-for="AccountRole" class="form-select">
                <option value="1">Staff</option>
                <option value="2">Lecturer</option>
                <option value="0">Admin</option>
            </select>
            <span asp-validation-for="AccountRole" class="text-danger"></span>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
    </div>
</form>
