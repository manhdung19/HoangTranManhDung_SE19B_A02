@model IEnumerable<FUNewsManagement.DAL.Models.NewsArticle>

@{
    ViewData["Title"] = "Tin tức mới nhất";
}

<div class="container mt-4">
    <h2 class="text-primary text-center mb-4 fw-bold">TIN TỨC MỚI NHẤT</h2>
    <hr />

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <h4 class="card-title fw-bold text-dark">@item.NewsTitle</h4>
                            <h6 class="card-subtitle mb-2 text-muted fst-italic">@item.Headline</h6>
                            <p class="card-text text-secondary mt-3">@item.NewsContent</p>
                        </div>
                        <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center">
                            <span class="badge bg-info text-dark px-3 py-2">
                                Danh mục: @(item.Category?.CategoryName ?? "Chung")
                            </span>
                            <small class="text-muted fw-bold">
                                🕒 @item.CreatedDate?.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center mt-5">
                <p class="text-muted fs-5">Hiện tại chưa có tin tức nào đang hoạt động. Hãy quay lại sau nhé!</p>
            </div>
        }
    </div>
</div>
