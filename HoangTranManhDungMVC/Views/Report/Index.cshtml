@model IEnumerable<FUNewsManagement.DAL.Models.NewsArticle>

@{
    ViewData["Title"] = "Report Statistics";
}

<div class="container mt-4">
    <h2>Báo Cáo Thống Kê Bài Viết</h2>
    <hr />

    <form asp-action="Index" method="get" class="row g-3 mb-4 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Từ ngày (StartDate)</label>
            <input type="date" name="startDate" value="@ViewData["StartDate"]" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Đến ngày (EndDate)</label>
            <input type="date" name="endDate" value="@ViewData["EndDate"]" class="form-control" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">Lọc Dữ Liệu</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Xóa Bộ Lọc</a>
        </div>
    </form>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Mã bài viết</th>
                <th>Tiêu đề (Title)</th>
                <th>Người tạo</th>
                <th>Ngày tạo</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center">Không có bài viết nào trong khoảng thời gian này.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.NewsArticleId</td>
                    <td>@item.NewsTitle</td>
                    <td>@(item.CreatedBy?.AccountName ?? "N/A")</td>
                    <td>@item.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(item.NewsStatus == true ? "Active" : "Inactive")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
