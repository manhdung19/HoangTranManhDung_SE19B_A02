@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HoangTranManhDungMVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HoangTranManhDungMVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">HoangTranManhDungMVC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <!-- Lấy thông tin Role và Tên từ Session -->
                    @{
                        var userRole = Context.Session.GetInt32("UserRole");
                        var userName = Context.Session.GetString("UserName");
                    }

                    <!-- MENU BÊN TRÁI: Dựa theo Role để hiển thị -->
                    <ul class="navbar-nav flex-grow-1">
                        @if (userRole == 0)
                        {
                            <!-- Dành cho Admin -->
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="SystemAccount" asp-action="Index">Quản lý Tài khoản</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="Report" asp-action="Index">Báo cáo Thống kê</a>
                            </li>
                        }
                        else if (userRole == 1)
                        {
                            <!-- Dành cho Staff -->
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="Category" asp-action="Index">Quản lý Danh mục</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="NewsArticle" asp-action="Index">Quản lý Bài viết</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="Profile" asp-action="Index">Hồ sơ & Lịch sử</a>
                            </li>
                        }
                        else if (userRole == 2)
                        {
                            <!-- Dành cho Lecturer -->
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="Lecturer" asp-action="Index">Đọc tin tức (Nội bộ)</a>
                            </li>
                        }
                        else
                        {
                            <!-- Dành cho Khách (Chưa đăng nhập) -->
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="Home" asp-action="Index">Tin tức Public</a>
                            </li>
                        }
                    </ul>

                    <!-- MENU BÊN PHẢI: Nút Đăng nhập / Đăng xuất -->
                    <ul class="navbar-nav">
                        @if (userName != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-primary fst-italic">Xin chào, @userName!</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-controller="Auth" asp-action="Logout">Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                            </li>
                        }
                    </ul>
                </div>

            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - HoangTranManhDungMVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
