@model IEnumerable<FUNewsManagement.DAL.Models.SystemAccount>

@{
    ViewData["Title"] = "Account Management";
}

<div class="container mt-4">
    <h2>Account Management</h2>
    <hr />

    <!-- Nút Create này tạm thời để trang trí, sau này sẽ gắn logic mở Popup -->
    <div class="d-flex justify-content-between mb-3">
        <!-- Nút Create -->
        <button class="btn btn-primary" onclick="openCreatePopup()">Create New Account</button>

        <!-- Form Tìm kiếm -->
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control me-2" placeholder="Tìm theo Tên hoặc Email..." style="width: 250px;" />
            <button type="submit" class="btn btn-secondary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Clear</a>
        </form>
    </div>


    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên</th>
                <th>Email</th>
                <th>Vai trò (Role)</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AccountId</td>
                    <td>@item.AccountName</td>
                    <td>@item.AccountEmail</td>
                    <td>
                        @(item.AccountRole == 1 ? "Staff" : item.AccountRole == 2 ? "Lecturer" : "Admin")
                    </td>
                    <td>
                        <button class="btn btn-warning btn-sm" onclick="openEditPopup(@item.AccountId)">Edit</button>
                        <button class="btn btn-danger btn-sm" onclick="deleteAccount(@item.AccountId)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="modal fade" id="accountModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" id="modal-content">
                <!-- Form HTML từ _Create.cshtml sẽ được tải bằng AJAX và nhét vào đây -->
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        // Hàm này gọi lên Controller lấy View Form về và mở Popup lên
        function openCreatePopup() {
            $.get('@Url.Action("Create", "SystemAccount")', function (data) {
                $('#modal-content').html(data);
                $('#accountModal').modal('show');
            });
        }

        // Hàm này bắt sự kiện khi bấm nút "Lưu" (Create)
        function submitCreateForm(form) {
            $.post(form.action, $(form).serialize(), function (response) {
                if (response.success) {
                    $('#accountModal').modal('hide');
                    location.reload();
                } else {
                    $('#modal-content').html(response);
                }
            });
            return false;
        }

        // Hàm lấy View Edit về và mở Popup
        function openEditPopup(id) {
            $.get('@Url.Action("Edit", "SystemAccount")/' + id, function (data) {
                $('#modal-content').html(data);
                $('#accountModal').modal('show');
            });
        }

        // Bắt sự kiện khi bấm nút "Lưu thay đổi" (Edit)
        function submitEditForm(form) {
            $.post(form.action, $(form).serialize(), function (response) {
                if (response.success) {
                    $('#accountModal').modal('hide');
                    location.reload();
                } else {
                    $('#modal-content').html(response);
                }
            });
            return false;
        }

        // Xử lý Delete có thông báo xác nhận (Confirmation)
        function deleteAccount(id) {
            if (confirm("Bạn có chắc chắn muốn xóa tài khoản này không? Hành động này không thể hoàn tác.")) {
                $.post('@Url.Action("Delete", "SystemAccount")/' + id, function (response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        alert("Lỗi: " + response.message);
                    }
                });
            }
        }
    </script>
}



