@model FUNewsManagement.DAL.Models.SystemAccount

@{
    ViewData["Title"] = "Manage Profile";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2>Thông tin cá nhân (Profile)</h2>
    <hr />

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="alert alert-success">@ViewBag.SuccessMessage</div>
    }

    <!-- Nút dẫn sang trang xem lịch sử bài viết -->
    <a asp-action="History" class="btn btn-info mb-4 text-white fw-bold">Xem lịch sử bài viết đã tạo</a>

    <form asp-action="Index" method="post" class="card p-4 shadow-sm border-0 bg-light">
        <div class="form-group mb-3">
            <label class="form-label fw-bold">Account ID</label>
            <input asp-for="AccountId" class="form-control" readonly />
        </div>
        <div class="form-group mb-3">
            <label class="form-label fw-bold">Tên của bạn (Name)</label>
            <input asp-for="AccountName" class="form-control" required />
            <span asp-validation-for="AccountName" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label fw-bold">Email</label>
            <input asp-for="AccountEmail" type="email" class="form-control" required />
            <span asp-validation-for="AccountEmail" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label fw-bold">Mật khẩu (Password)</label>
            <!-- Hiện kiểu text để người dùng có thể tự xem và sửa pass dễ dàng -->
            <input asp-for="AccountPassword" type="text" class="form-control" required />
            <span asp-validation-for="AccountPassword" class="text-danger"></span>
        </div>

        <!-- Ẩn Role vì Staff không được tự đổi Role của chính mình -->
        <input type="hidden" asp-for="AccountRole" />

        <div class="text-end mt-3">
            <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
        </div>
    </form>
</div>
